{
  "name": "@ad-platform/tracker-sdk",
  "version": "1.0.0",
  "description": "Client-side tracking SDK for Ad Recommendation Platform",
  "main": "dist/tracker.js",
  "module": "dist/tracker.esm.js",
  "types": "dist/tracker.d.ts",
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tracking",
    "analytics",
    "advertising",
    "user-behavior"
  ],
  "author": "Ad Platform Team",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.25",
    "@types/resolve": "^1.20.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "rollup": "^4.9.4",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "uuid": "^9.0.1"
  }
}
